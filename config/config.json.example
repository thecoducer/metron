{
  "server": {
    "callback_host": "127.0.0.1",
    "callback_port": 5000,
    "callback_path": "/callback",
    "ui_host": "127.0.0.1",
    "ui_port": 8000
  },
  "timeouts": {
    "request_token_timeout_seconds": 180,
    "auto_refresh_interval_seconds": 60
  },
  "features": {
    "auto_refresh_outside_market_hours": false
  },

  "_comment_google_oauth": "See README for setup instructions",
  "google_oauth": {
    "client_secrets_file": "config/google-oauth-credentials.json"
  },

  "_comment_firebase": "Firebase service-account JSON for Firestore user storage",
  "firebase": {
    "credentials_file": "config/firebase-credentials.json"
  }
}
