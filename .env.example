# Metron — Environment Configuration
# Copy to .env and edit as needed. All values below are the defaults.

# Server
METRON_UI_HOST=127.0.0.1
METRON_UI_PORT=8000

# Timeouts (seconds)
METRON_REQUEST_TOKEN_TIMEOUT=180

# Features
METRON_ALLOW_BROWSER_API_ACCESS=false

# SigNoz
# JWT secret for SigNoz auth tokens (change this!)
SIGNOZ_JWT_SECRET=metron-signoz-secret-change-me
