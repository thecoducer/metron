                "dataType": "float64",
                "isColumn": false
              },
              "timeAggregation": "p95",
              "spaceAggregation": "p95",
              "filters": {"items": [], "op": "AND"},
              "groupBy": [{"key": "api.name", "type": "tag", "dataType": "string"}],
              "expression": "A",
              "disabled": false,
              "legend": "{{api.name}}",
              "reduceTo": "last"
            }
          ],
          "queryFormulas": []
        }
      }
    },
    {
      "id": "portfolio_fetches",
