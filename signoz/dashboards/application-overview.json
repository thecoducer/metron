    {
      "id": "request_rate",
      "title": "Request Rate (req/s)",
      "description": "Total HTTP requests per second",
      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "metrics",
              "queryName": "A",
              "aggregateOperator": "rate",
              "aggregateAttribute": {
                "key": "http_requests_total",
                "type": "Sum",
                "dataType": "float64",
                "isColumn": false
              },
              "timeAggregation": "rate",
              "spaceAggregation": "sum",
              "functions": [],
              "filters": {
                "items": [],
                "op": "AND"
              },
              "expression": "A",
              "disabled": false,
              "legend": "Requests/s",
              "reduceTo": "last"
            }
          ],
          "queryFormulas": []
        }
      }
    },
    {
      "id": "error_rate",
