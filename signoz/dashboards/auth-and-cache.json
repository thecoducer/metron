{
  "title": "Metron - Auth & User Activity",
  "description": "Authentication events, PIN operations, cache performance, and application errors",
  "tags": ["metron", "auth", "cache"],
  "layout": [
    {"h": 3, "i": "auth_events", "w": 6, "x": 0, "y": 0},
    {"h": 3, "i": "auth_failures", "w": 6, "x": 6, "y": 0},
    {"h": 3, "i": "cache_hits", "w": 6, "x": 0, "y": 3},
    {"h": 3, "i": "cache_hit_ratio", "w": 6, "x": 6, "y": 3},
    {"h": 3, "i": "app_errors", "w": 6, "x": 0, "y": 6},
    {"h": 3, "i": "errors_by_category", "w": 6, "x": 6, "y": 6}
  ],
  "widgets": [
    {
      "id": "auth_events",
      "title": "Authentication Events",
      "description": "Login, logout, PIN verify, and Zerodha auth events",
      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "metrics",
              "queryName": "A",
              "aggregateOperator": "rate",
              "aggregateAttribute": {
                "key": "auth_events_total",
                "type": "Sum",
                "dataType": "float64",
                "isColumn": false
              },
              "timeAggregation": "rate",
              "spaceAggregation": "sum",
              "filters": {"items": [], "op": "AND"},
              "groupBy": [{"key": "auth.event", "type": "tag", "dataType": "string"}],
              "expression": "A",
              "disabled": false,
              "legend": "{{auth.event}}",
              "reduceTo": "last"
            }
          ],
          "queryFormulas": []
        }
      }
    },
    {
      "id": "auth_failures",
      "title": "Auth Failures",
      "description": "Failed authentication attempts",
      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "metrics",
              "queryName": "A",
              "aggregateOperator": "rate",
              "aggregateAttribute": {
                "key": "auth_events_total",
                "type": "Sum",
                "dataType": "float64",
                "isColumn": false
              },
              "timeAggregation": "rate",
              "spaceAggregation": "sum",
              "filters": {
                "items": [
                  {
                    "key": {"key": "auth.success", "type": "tag", "dataType": "string"},
                    "op": "=",
                    "value": "False"
                  }
                ],
                "op": "AND"
              },
              "groupBy": [{"key": "auth.event", "type": "tag", "dataType": "string"}],
              "expression": "A",
              "disabled": false,
              "legend": "{{auth.event}} failures",
              "reduceTo": "last"
            }
          ],
          "queryFormulas": []
        }
      }
    },
    {
      "id": "cache_hits",
      "title": "Cache Hits vs Misses",
      "description": "Cache hit and miss rates by cache type",
      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "metrics",
              "queryName": "A",
              "aggregateOperator": "rate",
              "aggregateAttribute": {
                "key": "cache_hits_total",
                "type": "Sum",
                "dataType": "float64",
                "isColumn": false
              },
              "timeAggregation": "rate",
              "spaceAggregation": "sum",
              "filters": {"items": [], "op": "AND"},
              "groupBy": [{"key": "cache.name", "type": "tag", "dataType": "string"}],
              "expression": "A",
              "disabled": false,
              "legend": "hit: {{cache.name}}",
              "reduceTo": "last"
            },
            {
              "dataSource": "metrics",
              "queryName": "B",
              "aggregateOperator": "rate",
              "aggregateAttribute": {
                "key": "cache_misses_total",
                "type": "Sum",
                "dataType": "float64",
                "isColumn": false
              },
              "timeAggregation": "rate",
              "spaceAggregation": "sum",
              "filters": {"items": [], "op": "AND"},
              "groupBy": [{"key": "cache.name", "type": "tag", "dataType": "string"}],
              "expression": "B",
              "disabled": false,
              "legend": "miss: {{cache.name}}",
              "reduceTo": "last"
            }
          ],
          "queryFormulas": []
        }
      }
    },
    {
      "id": "cache_hit_ratio",
      "title": "Cache Hit Ratio",
      "description": "Percentage of cache requests that were hits",
      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "metrics",
              "queryName": "A",
              "aggregateOperator": "rate",
              "aggregateAttribute": {
                "key": "cache_hits_total",
                "type": "Sum",
                "dataType": "float64",
                "isColumn": false
              },
              "timeAggregation": "rate",
              "spaceAggregation": "sum",
              "filters": {"items": [], "op": "AND"},
              "expression": "A",
              "disabled": true,
              "legend": "",
              "reduceTo": "last"
            },
            {
              "dataSource": "metrics",
              "queryName": "B",
              "aggregateOperator": "rate",
              "aggregateAttribute": {
                "key": "cache_misses_total",
                "type": "Sum",
                "dataType": "float64",
                "isColumn": false
              },
              "timeAggregation": "rate",
              "spaceAggregation": "sum",
              "filters": {"items": [], "op": "AND"},
              "expression": "B",
              "disabled": true,
              "legend": "",
              "reduceTo": "last"
            }
          ],
          "queryFormulas": [
            {
              "expression": "A / (A + B) * 100",
              "queryName": "F1",
              "legend": "Hit Ratio %",
              "disabled": false
            }
          ]
        }
      }
    },
    {
      "id": "app_errors",
      "title": "Application Error Rate",
      "description": "Application errors per second",
      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "metrics",
              "queryName": "A",
              "aggregateOperator": "rate",
              "aggregateAttribute": {
                "key": "errors_total",
                "type": "Sum",
                "dataType": "float64",
                "isColumn": false
              },
              "timeAggregation": "rate",
              "spaceAggregation": "sum",
              "filters": {"items": [], "op": "AND"},
              "expression": "A",
              "disabled": false,
              "legend": "Errors/s",
              "reduceTo": "last"
            }
          ],
          "queryFormulas": []
        }
      }
    },
    {
      "id": "errors_by_category",
      "title": "Errors by Category",
      "description": "Application errors grouped by error category",
      "panelTypes": "graph",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "metrics",
              "queryName": "A",
              "aggregateOperator": "rate",
              "aggregateAttribute": {
                "key": "errors_total",
                "type": "Sum",
                "dataType": "float64",
                "isColumn": false
              },
              "timeAggregation": "rate",
              "spaceAggregation": "sum",
              "filters": {"items": [], "op": "AND"},
              "groupBy": [{"key": "error.category", "type": "tag", "dataType": "string"}],
              "expression": "A",
              "disabled": false,
              "legend": "{{error.category}}",
              "reduceTo": "last"
            }
          ],
          "queryFormulas": []
        }
      }
    }
  ]
}
